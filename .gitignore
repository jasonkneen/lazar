# ─── compiled artifacts ─────────────────────────────────────────────
src/target/
bin/lazar

# ─── runtime state (per-user, generated by lazar at runtime) ────────
# These directories live at the repo/install root. Keep these patterns root-
# anchored so source paths like src/seed-skills/memory/ remain tracked.
/skills/
/memory/
/workspace/
/logs/

# ─── editor / IDE ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS cruft ───────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# ─── secrets / local env ────────────────────────────────────────────
.env
.env.local
*.local

# Note on Cargo.lock:
# We DO commit src/Cargo.lock — lazar is a binary, not a library, and
# locking dependency versions makes reproducible builds across machines.
